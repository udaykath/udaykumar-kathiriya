{% schema %}
{
  "name": "Gift Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo Image" },
    { "type": "text", "id": "center_text", "label": "Center Text", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "CHOOSE GIFT" }
  ]
}
{% endschema %}

<header class="gift-header">

  <div class="header-inner">

    <!-- MOBILE MENU ICON (UPDATED) -->
    <div class="mobile-menu">
      <span class="icon-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="12">
          <path d="M1 6H19M1 1H19M1 11H19" stroke="black" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </span>

      <span class="icon-close">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15">
          <path d="M1 14L14 1M1 1L14 14" stroke="black" stroke-width="2"/>
        </svg>
      </span>
    </div>

    <!-- LOGO -->
    <div class="logo">
      {% if section.settings.logo != blank %}
        <a href="{{ routes.root_url }}">
          <img src="{{ section.settings.logo | img_url: 'master' }}">
        </a>
      {% endif %}
    </div>

    <!-- CENTER TEXT -->
    <div class="center-text">
      {{ section.settings.center_text }}
    </div>

    <!-- BUTTON -->
    <div class="cta">
      <button>
        {{ section.settings.btn_text }}
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="12">
          <path d="M0.75 4.77298L24.75 4.77298" stroke="black" stroke-width="1.5"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- MOBILE DRAWER (SIMPLIFIED) -->
  <div class="mobile-drawer">
    <div class="drawer-inner">

      <div class="drawer-text">
        {{ section.settings.center_text }}
      </div>

      <div class="drawer-btn">
        <button>{{ section.settings.btn_text }} →</button>
      </div>

    </div>
  </div>

</header>