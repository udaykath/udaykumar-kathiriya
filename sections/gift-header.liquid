{% schema %}
{
  "name": "Gift Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo Image" },
    { "type": "text", "id": "center_text", "label": "Center Text", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "CHOOSE GIFT" }
  ]
}
{% endschema %}

<header class="gift-header">

  <div class="header-inner">

    <!-- MOBILE MENU ICON -->
    <div class="mobile-menu">☰</div>

    <!-- LOGO -->
    <div class="logo">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | img_url: 'master' }}">
      {% endif %}
    </div>

    <!-- CENTER TEXT -->
    <div class="center-text">
      {{ section.settings.center_text }}
    </div>

    <!-- BUTTON -->
    <div class="cta">
      <button>{{ section.settings.btn_text }} →</button>
    </div>

  </div>

  <!-- MOBILE DRAWER -->
  <div class="mobile-drawer">

    <div class="drawer-inner">

      <div class="drawer-top">
        <span class="close-drawer">✕</span>
        <div class="drawer-logo">
          {% if section.settings.logo != blank %}
            <img src="{{ section.settings.logo | img_url: 'master' }}">
          {% endif %}
        </div>
      </div>

      <div class="drawer-text">
        {{ section.settings.center_text }}
      </div>

      <div class="drawer-btn">
        <button>{{ section.settings.btn_text }} →</button>
      </div>

    </div>

  </div>

</header>